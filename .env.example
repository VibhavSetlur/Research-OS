# Research OS — Environment Variables
# Copy to .env (or export directly in your shell) before starting the server.
# The file is gitignored — never commit real keys.

# ── Literature & Search (all optional) ───────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=  # https://www.semanticscholar.org/product/api
FIRECRAWL_API_KEY=         # https://firecrawl.io  — web search / scrape
SERPAPI_KEY=               # https://serpapi.com   — Google Scholar wrapper
PUBMED_API_KEY=            # https://www.ncbi.nlm.nih.gov/account/ (NCBI e-utils)
CROSSREF_API_KEY=          # https://www.crossref.org  — polite-pool access

# ── Server Configuration ──────────────────────────────────────────────────────
# RESEARCH_OS_TRANSPORT=stdio   # stdio (default) | sse | http
# RESEARCH_OS_PORT=8080         # Only used for sse/http transport
# RESEARCH_OS_LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
