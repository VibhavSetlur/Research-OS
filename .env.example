# Research OS — environment variables
#
# Research OS does NOT manage LLM provider keys. Your AI client (Claude Code,
# OpenCode, Antigravity IDE, etc.) handles model access on its own side.
#
# Optional credentials below are for the literature / search / scraping APIs
# the MCP server uses internally. Prefer setting them inside
# inputs/researcher_config.yaml — the server will export them as env vars
# at startup so they travel with the project.
#
# This file is gitignored — never commit real keys.

# ── Literature / search ────────────────────────────────────────────────
SEMANTIC_SCHOLAR_API_KEY=   # https://www.semanticscholar.org/product/api
S2_API_KEY=                 # alias — some SDKs read this name
NCBI_API_KEY=               # https://www.ncbi.nlm.nih.gov/account/ (PubMed)
CROSSREF_API_KEY=           # https://www.crossref.org

# ── Web search / scraping ─────────────────────────────────────────────
FIRECRAWL_API_KEY=          # https://firecrawl.io
SERPAPI_API_KEY=            # https://serpapi.com  (fallback web search)

# ── Runtime ────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
