// Nextflow config: ERα ChIP-seq pipeline
// Two profiles: `test` (local docker, tiny inputs) and `full` (SLURM cluster).

manifest {
    name        = 'chipseq-eralpha'
    description = 'ERα ChIP-seq: MCF-7 vs T47D'
    mainScript  = 'main.nf'
    version     = '0.1.0'
}

docker.enabled = true

executor {
    queueSize     = 50
    submitRateLimit = '10 sec'
}

profiles {
    test {
        executor = 'local'
        process.cpus   = 2
        process.memory = '4 GB'
        params.reads   = "$projectDir/test_data/*_{R1,R2}.fastq.gz"
    }

    full {
        executor = 'slurm'
        process.queue  = 'compute'
        process.clusterOptions = '--account=chipseq_eralpha'
        process.errorStrategy = 'retry'
        process.maxRetries = 2
    }
}
